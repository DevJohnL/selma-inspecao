# Conexão com o Supabase (use a Service Role Key — ignora RLS, igual às edge functions)
SUPABASE_URL=https://bgviqefqedowwsjgxdds.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Google Generative Language API) — legado, não mais usado no relatório
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (usado na geração do relatório)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram (bot.py) e link do formulário no Streamlit
TELEGRAM_BOT_TOKEN=
# URL base do app no Streamlit Cloud (sem barra no fim). Local: http://localhost:8501
STREAMLIT_APP_URL=http://localhost:8501

# WhatsApp via Evolution API (whatsapp_bot.py)
# URL base da instância Evolution (sem barra no fim)
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=default
# Chave de API global da Evolution (AUTHENTICATION_API_KEY), enviada como apikey
EVOLUTION_API_KEY=
# Porta onde o webhook Flask escuta (aponte o webhook da Evolution para /webhook).
# Usada apenas no modo dev (app.run). Em produção no Railway o gunicorn faz o
# bind na porta do $PORT, então esta variável não precisa ser configurada lá.
WHATSAPP_BOT_PORT=8080
